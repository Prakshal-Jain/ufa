# Copy to .env and `source` it, or export these directly.
# Option A — OpenRouter (model diversity: Claude/GPT/Grok/GLM/open, one key)
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=sk-or-...
ATTACKER_MODEL=openai/gpt-4o-mini
DEFENDER_MODEL=z-ai/glm-4.6

# Option B — z.ai gateway (GLM only, the sponsor model)
# LLM_BASE_URL=https://api.z.ai/api/paas/v4
# LLM_API_KEY=<z.ai key>
# ATTACKER_MODEL=glm-4.6
# DEFENDER_MODEL=glm-4.6
